# Use an Atlas Database Access user (not your Atlas website login).
# Percent-encode password characters such as @, :, /, ?, #, [ and ].
MONGODB_URI=mongodb+srv://<database-user>:<url-encoded-password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGODB_DB=tasteloop
PORT=5000
CLIENT_URL=http://localhost:5173
JWT_SECRET=<generate-a-long-random-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Password reset: enable debug only for local development. Debug responses
# include the reset token instead of sending email.
PASSWORD_RESET_EXPIRE_MINUTES=30
PASSWORD_RESET_DEBUG=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
